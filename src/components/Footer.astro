---
import Icon from './Icon.astro';

const currentYear = new Date().getFullYear();
---

<footer>
	<div class="group">
		<p>
			Built with <a href="https://astro.build/">Astro</a>
			<Icon icon="rocket-launch" size="1.2em" />
		</p>
		<p>&copy; {currentYear} Vidhya Divakar</p>
	</div>
	<p class="socials">
		<a href="https://github.com/REPLACE_WITH_YOUR_GITHUB"> GitHub</a>
		<a href="https://linkedin.com/in/REPLACE_WITH_YOUR_LINKEDIN"> LinkedIn</a>
	</p>
</footer>
<style>
	footer {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-top: auto;
		padding: 2rem 1.5rem;
		text-align: center;
		color: var(--gray-400);
		font-size: var(--text-sm);
		border-top: 1px solid var(--gray-800);
		background: var(--gray-900);
	}

	footer a {
		color: var(--gray-400);
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	footer a:hover,
	footer a:focus {
		color: var(--accent-regular);
	}

	.group {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.socials {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	@media (min-width: 50em) {
		footer {
			flex-direction: row;
			justify-content: space-between;
			align-items: center;
			padding: 1.5rem 2.5rem;
		}

		.group {
			flex-direction: row;
			gap: 1.5rem;
		}

		.socials {
			justify-content: flex-end;
		}
	}
</style>
