---
const categories = [
	{
		id: 'writing',
		label: 'Technical Writing & Documentation',
		skills: [
			'Product documentation', 'User manuals', 'Admin & configuration guides',
			'Online help systems', 'API documentation', 'Release notes',
			'Troubleshooting guides', 'Process flows', 'UX writing',
			'DITA structured authoring', 'Markdown', 'HTML/XML documentation',
		],
	},
	{
		id: 'api',
		label: 'API & Integration',
		skills: [
			'REST APIs', 'GraphQL', 'Endpoint modeling',
			'OAuth', 'JWT', 'MSAL',
			'JSON', 'YAML', 'Request/response documentation',
			'API integration workflows', 'Swagger', 'Postman',
		],
	},
	{
		id: 'tools',
		label: 'Tools & Platforms',
		skills: [
			'Confluence', 'SharePoint', 'Adobe FrameMaker',
			'MadCap Flare', 'Oxygen XML', 'Adobe Experience Manager',
			'RoboHelp', 'GitHub', 'VS Code',
			'FileZilla',
		],
	},
	{
		id: 'programming',
		label: 'Programming & Technical Knowledge',
		skills: [
			'JavaScript', 'Python', 'Java',
			'C++', 'PHP', 'HTML',
			'CSS', 'XML', 'JSON', 'YAML',
			'OOP concepts', 'System behavior documentation',
		],
	},
	{
		id: 'testing',
		label: 'Testing & QA',
		skills: [
			'Manual testing', 'Automation testing', 'STLC',
			'Bug lifecycle', 'Test case writing', 'Basic SQL',
			'Selenium', 'TestLink', 'Zephyr',
		],
	},
	{
		id: 'agile',
		label: 'Agile & Collaboration',
		skills: [
			'Jira', 'Redmine', 'Agile/Scrum',
			'Cross-functional collaboration', 'Product teams', 'Development teams',
			'QA teams', 'Support teams',
		],
	},
	{
		id: 'ai',
		label: 'AI & Modern Tools',
		skills: [
			'GPT-based tools', 'Claude', 'GitHub Copilot',
			'VS Code Copilot', 'AI-assisted documentation', 'Figma (Make)',
			'Content automation', 'CI/CD workflows', 'Docs-as-Code',
		],
	},
	{
		id: 'ux',
		label: 'UX & Design Tools',
		skills: [
			'Figma', 'Draw.io', 'MS Visio',
			'Canva', 'Adobe Illustrator', 'Android Studio',
			'Snipping Tool',
		],
	},
];
---

<div class="accordion">
	<h2 class="accordion-title">Skills & Abilities</h2>
	{
		categories.map((cat, i) => (
			<div class="accordion-item">
				<button
					class:list={['accordion-header', { open: i === 0 }]}
					aria-expanded={i === 0 ? 'true' : 'false'}
					data-accordion
				>
					<span class="cat-label">{cat.label}</span>
					<span class="cat-meta">
						<span class="badge">{cat.skills.length}</span>
						<span class="chevron" aria-hidden="true">▶</span>
					</span>
				</button>
				<div class:list={['accordion-body', { open: i === 0 }]}>
					<div class="skill-chips">
						{cat.skills.map((s) => <span class="chip">{s}</span>)}
					</div>
				</div>
			</div>
		))
	}
</div>

<script>
	document.querySelectorAll('[data-accordion]').forEach((btn) => {
		btn.addEventListener('click', () => {
			const isOpen = btn.classList.contains('open');
			const body = btn.nextElementSibling as HTMLElement;
			btn.classList.toggle('open', !isOpen);
			btn.setAttribute('aria-expanded', String(!isOpen));
			body.classList.toggle('open', !isOpen);
		});
	});
</script>

<style>
	.accordion {
		border: 1px solid #252525;
		border-radius: 0.5rem;
		overflow: hidden;
	}

	.accordion-title {
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #f5f5f5;
		padding: 1rem 1.25rem;
		border-bottom: 1px solid #252525;
		background: #1a1f2e;
		margin: 0;
	}

	.accordion-item {
		border-top: 1px solid #252525;
	}

	.accordion-header {
		width: 100%;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.875rem 1.25rem;
		background: #0f1117;
		border: none;
		cursor: pointer;
		font-size: 0.85rem;
		font-weight: 500;
		color: #b4b4b4;
		text-align: left;
		transition: background 0.2s, color 0.2s;
		gap: 1rem;
	}

	.accordion-header:hover,
	.accordion-header.open {
		background: #141928;
		color: #d4b896;
	}

	.cat-label {
		flex: 1;
	}

	.cat-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-shrink: 0;
	}

	.badge {
		font-size: 0.68rem;
		font-weight: 600;
		padding: 0.15rem 0.5rem;
		border-radius: 999px;
		background: rgba(212, 184, 150, 0.12);
		color: #d4b896;
	}

	.chevron {
		font-size: 0.6rem;
		color: #b4b4b4;
		transition: transform 0.2s ease;
		display: inline-block;
	}

	.accordion-header.open .chevron {
		transform: rotate(90deg);
		color: #d4b896;
	}

	.accordion-body {
		display: none;
		padding: 0.75rem 1.25rem 1rem;
		background: #0f1117;
		border-top: 1px solid #252525;
	}

	.accordion-body.open {
		display: block;
	}

	.skill-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.chip {
		font-size: 0.78rem;
		padding: 0.25rem 0.65rem;
		border-radius: 0.25rem;
		background: rgba(212, 184, 150, 0.08);
		color: #d4b896;
		border: 1px solid rgba(212, 184, 150, 0.2);
		transition: background 0.2s, border-color 0.2s;
	}

	.chip:hover {
		background: rgba(212, 184, 150, 0.15);
		border-color: #d4b896;
	}
</style>
