---
import MainHead from '../components/MainHead.astro';
---

<html lang="en">
<head>
	<MainHead
		title="About | Vidhya Divakar"
		description="Full background, education, tools, and more about Vidhya Divakar — Senior Technical Documentation Professional."
	/>
</head>
<body>

<div class="page">

	<header class="top-nav">
		<a href="/" class="back-link">
			<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="10,3 5,8 10,13"/></svg>
			Back
		</a>
		<span class="top-name">Vidhya Divakar</span>
	</header>

	<main class="content">

		<div class="page-title">
			<h1>Background <span class="amp">&</span> Education</h1>
			<p class="subtitle">The full picture — where I've been, what I've studied, and how I work.</p>
		</div>

		<!-- CAREER TIMELINE -->
		<section class="section">
			<h2 class="section-heading">
				<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><rect x="1.5" y="2.5" width="13" height="11" rx="1.5"/><polyline points="4,7 6.5,9.5 4,12"/><line x1="9" y1="12" x2="12.5" y2="12"/></svg>
				Career Timeline
			</h2>
			<div class="timeline">

				<div class="tl-item current">
					<div class="tl-marker"></div>
					<div class="tl-body">
						<div class="tl-meta">
							<span class="tl-period">Feb 2026 – Present</span>
							<span class="tl-badge">Current</span>
						</div>
						<p class="tl-role">Full-Stack MERN Development</p>
						<p class="tl-org">Per Scholas · Atlanta, GA</p>
						<p class="tl-desc">AI Native Software Development program — building full-stack applications with MongoDB, Express, React, and Node.js alongside modern engineering practices.</p>
					</div>
				</div>

				<div class="tl-item">
					<div class="tl-marker"></div>
					<div class="tl-body">
						<div class="tl-meta">
							<span class="tl-period">Sep 2020 – Dec 2022</span>
						</div>
						<p class="tl-role">Senior Technical Writer</p>
						<p class="tl-org">Sedin Technologies</p>
						<p class="tl-desc">Led documentation for enterprise SaaS and logistics platforms. Delivered API specs, configuration guides, and Docs-as-Code workflows across cross-functional teams.</p>
					</div>
				</div>

				<div class="tl-item gap">
					<div class="tl-marker"></div>
					<div class="tl-body">
						<div class="tl-meta">
							<span class="tl-period">2018 – 2020</span>
							<span class="tl-badge gap-badge">Career Break</span>
						</div>
						<p class="tl-desc">Personal sabbatical — relocation, family commitments, and self-directed learning.</p>
					</div>
				</div>

				<div class="tl-item">
					<div class="tl-marker"></div>
					<div class="tl-body">
						<div class="tl-meta">
							<span class="tl-period">Feb 2016 – Nov 2018</span>
						</div>
						<p class="tl-role">Technical Writer</p>
						<p class="tl-org">Multisoft Virtual Academy</p>
						<p class="tl-desc">Created course content, instructor guides, and eLearning documentation for technology and business training programs.</p>
					</div>
				</div>

				<div class="tl-item">
					<div class="tl-marker"></div>
					<div class="tl-body">
						<div class="tl-meta">
							<span class="tl-period">Feb 2015 – Oct 2015</span>
						</div>
						<p class="tl-role">Technical Writer</p>
						<p class="tl-org">HCL Technologies</p>
						<p class="tl-desc">Authored enterprise product documentation and release notes for large-scale software systems within an SDLC environment.</p>
					</div>
				</div>

				<div class="tl-item">
					<div class="tl-marker"></div>
					<div class="tl-body">
						<div class="tl-meta">
							<span class="tl-period">Feb 2012 – Feb 2015</span>
						</div>
						<p class="tl-role">Technical Writer</p>
						<p class="tl-org">Navis India Technologies</p>
						<p class="tl-desc">Core contributor to Navis N4 documentation from the 2.x era. Produced configuration guides, reference data manuals, and operational workflows for port and terminal systems.</p>
					</div>
				</div>

				<div class="tl-item">
					<div class="tl-marker"></div>
					<div class="tl-body">
						<div class="tl-meta">
							<span class="tl-period">May 2010 – Feb 2012</span>
						</div>
						<p class="tl-role">Technical Writer</p>
						<p class="tl-org">Ramco / Lionbridge</p>
						<p class="tl-desc">Began career producing user manuals and help documentation for ERP and enterprise software. Developed foundational skills in structured authoring and content management.</p>
					</div>
				</div>

			</div>
		</section>

		<!-- EDUCATION -->
		<section class="section">
			<h2 class="section-heading">
				<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 6l6-4 6 4-6 4-6-4z"/><path d="M5 8.5v4c1 .8 2 1 3 1s2-.2 3-1v-4"/><line x1="14" y1="6" x2="14" y2="10"/></svg>
				Education
			</h2>
			<div class="edu-cards">

				<div class="edu-card highlight">
					<div class="edu-top">
						<div>
							<p class="edu-school">Per Scholas</p>
							<p class="edu-degree">AI Native Software Development</p>
							<p class="edu-sub">Full-Stack MERN — MongoDB, Express, React, Node.js</p>
						</div>
						<span class="edu-year">2026</span>
					</div>
					<p class="edu-location">Atlanta, GA · Feb – Jun 2026</p>
					<div class="edu-tags">
						<span>React</span><span>Node.js</span><span>MongoDB</span><span>Express</span><span>TypeScript</span>
					</div>
				</div>

				<div class="edu-card">
					<div class="edu-top">
						<div>
							<p class="edu-school">TestLeaf</p>
							<p class="edu-degree">Automation Testing</p>
							<p class="edu-sub">Java, Selenium, TestNG, Cucumber, Apache POI, REST APIs</p>
						</div>
						<span class="edu-year">2026</span>
					</div>
					<p class="edu-location">Atlanta, GA · Oct 2025 – Feb 2026</p>
					<div class="edu-tags">
						<span>Selenium</span><span>Java</span><span>TestNG</span><span>REST APIs</span>
					</div>
				</div>

				<div class="edu-card">
					<div class="edu-top">
						<div>
							<p class="edu-school">Anna University</p>
							<p class="edu-degree">B.E. in Electronics & Communication</p>
							<p class="edu-sub">GPA 8.6 / 10</p>
						</div>
						<span class="edu-year">2009</span>
					</div>
					<p class="edu-location">Chennai, India · Nov 2009</p>
					<div class="edu-tags">
						<span>Electronics</span><span>Communication Systems</span><span>Engineering</span>
					</div>
				</div>

			</div>
		</section>

		<!-- TOOLS -->
		<section class="section">
			<h2 class="section-heading">
				<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><rect x="4" y="4" width="8" height="8" rx="1"/><line x1="6" y1="4" x2="6" y2="2"/><line x1="10" y1="4" x2="10" y2="2"/><line x1="6" y1="14" x2="6" y2="12"/><line x1="10" y1="14" x2="10" y2="12"/><line x1="4" y1="6" x2="2" y2="6"/><line x1="4" y1="10" x2="2" y2="10"/><line x1="14" y1="6" x2="12" y2="6"/><line x1="14" y1="10" x2="12" y2="10"/></svg>
				Tools I Work With
			</h2>
			<div class="tools-grid">

				<div class="tool-group">
					<p class="tool-label">Documentation</p>
					<div class="tool-chips">
						<span>Confluence</span><span>Adobe FrameMaker</span><span>MadCap Flare</span>
						<span>Oxygen XML</span><span>RoboHelp</span><span>AEM</span><span>SharePoint</span>
					</div>
				</div>

				<div class="tool-group">
					<p class="tool-label">Development & API</p>
					<div class="tool-chips">
						<span>VS Code</span><span>GitHub</span><span>Postman</span><span>Swagger</span>
						<span>REST APIs</span><span>JSON</span><span>YAML</span>
					</div>
				</div>

				<div class="tool-group">
					<p class="tool-label">Testing & QA</p>
					<div class="tool-chips">
						<span>Selenium</span><span>TestNG</span><span>Zephyr</span>
						<span>TestLink</span><span>Manual Testing</span>
					</div>
				</div>

				<div class="tool-group">
					<p class="tool-label">Project & Collaboration</p>
					<div class="tool-chips">
						<span>Jira</span><span>Redmine</span><span>Agile / Scrum</span>
					</div>
				</div>

				<div class="tool-group">
					<p class="tool-label">AI & Automation</p>
					<div class="tool-chips">
						<span>Claude</span><span>GitHub Copilot</span><span>ChatGPT</span>
						<span>Figma Make</span><span>Docs-as-Code</span>
					</div>
				</div>

				<div class="tool-group">
					<p class="tool-label">Design & Diagrams</p>
					<div class="tool-chips">
						<span>Figma</span><span>Draw.io</span><span>MS Visio</span><span>Canva</span>
					</div>
				</div>

			</div>
		</section>

		<!-- LANGUAGES -->
		<section class="section">
			<h2 class="section-heading">
				<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="8" cy="8" r="6.5"/><path d="M8 1.5c-2 2.5-2 8.5 0 13"/><path d="M8 1.5c2 2.5 2 8.5 0 13"/><line x1="1.5" y1="8" x2="14.5" y2="8"/></svg>
				Languages
			</h2>
			<div class="lang-list">
				<div class="lang-item">
					<span class="lang-name">English</span>
					<span class="lang-level">Professional — documentation, communication, writing</span>
				</div>
				<div class="lang-item">
					<span class="lang-name">Tamil</span>
					<span class="lang-level">Native</span>
				</div>
			</div>
		</section>

		<!-- BEYOND WORK -->
		<section class="section">
			<h2 class="section-heading">
				<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 13.5C4 13.5 1.5 8 1.5 8S4 2.5 8 2.5 14.5 8 14.5 8 12 13.5 8 13.5z"/><circle cx="8" cy="8" r="2"/></svg>
				Beyond Work
			</h2>
			<div class="beyond-grid">

				<div class="beyond-card">
					<p class="beyond-title">Reading</p>
					<p class="beyond-desc">Books are a constant — fiction, non-fiction, tech. You can follow along on Goodreads.</p>
					<a href="https://www.goodreads.com/user/show/186501107-vidhya-divakar" target="_blank" rel="noopener" class="beyond-link">
						Goodreads profile
						<svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 9.5l7-7M4 2.5h5.5V8"/></svg>
					</a>
				</div>

				<div class="beyond-card">
					<p class="beyond-title">Currently Learning</p>
					<p class="beyond-desc">MERN stack, TypeScript, system design, and modern frontend patterns. Building projects to go alongside documentation expertise.</p>
				</div>

				<div class="beyond-card">
					<p class="beyond-title">Technical Writing Community</p>
					<p class="beyond-desc">Interested in Docs-as-Code, API documentation tooling, and the evolving role of AI in technical writing workflows.</p>
				</div>

			</div>
		</section>

		<!-- RESUME -->
		<section class="section resume-section">
			<p class="resume-text">Want the full picture in one document?</p>
			<a href="#" class="resume-btn">
				<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 1v9M5 7l3 3 3-3"/><rect x="2" y="11" width="12" height="3" rx="1"/></svg>
				Download Resume
			</a>
		</section>

	</main>
</div>

</body>
</html>

<style>
	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

	:root {
		--bg:      #0c0c0c;
		--surface: #0f1117;
		--left:    #1a1f2e;
		--border:  #252525;
		--text:    #f5f5f5;
		--muted:   #b4b4b4;
		--accent:  #d4b896;
		--font-sans: 'Inter', system-ui, -apple-system, sans-serif;
		--font-mono: 'JetBrains Mono', 'Fira Code', monospace;
	}

	html, body { height: 100%; background: var(--bg); color: var(--text); font-family: var(--font-sans); }

	/* TOP NAV */
	.top-nav {
		position: sticky;
		top: 0;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 4vw;
		background: rgba(12,12,12,0.85);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border);
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.82rem;
		font-weight: 600;
		font-family: var(--font-mono);
		color: var(--muted);
		text-decoration: none;
		letter-spacing: 0.05em;
		transition: color 0.2s;
	}
	.back-link:hover { color: var(--accent); }

	.top-name {
		font-size: 0.8rem;
		font-family: var(--font-mono);
		color: var(--muted);
		letter-spacing: 0.08em;
	}

	/* PAGE LAYOUT */
	.page { min-height: 100vh; }

	.content {
		max-width: 860px;
		margin: 0 auto;
		padding: 4rem 4vw 6rem;
		display: flex;
		flex-direction: column;
		gap: 4rem;
	}

	/* PAGE TITLE */
	.page-title h1 {
		font-size: clamp(1.8rem, 4vw, 2.8rem);
		font-weight: 700;
		color: var(--text);
		line-height: 1.15;
	}
	.amp { color: var(--accent); }
	.subtitle {
		margin-top: 0.75rem;
		font-size: 0.95rem;
		color: var(--muted);
		line-height: 1.7;
	}

	/* SECTION */
	.section { display: flex; flex-direction: column; gap: 1.5rem; }

	.section-heading {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-size: 0.72rem;
		font-weight: 700;
		font-family: var(--font-mono);
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
	}

	/* TIMELINE */
	.timeline {
		display: flex;
		flex-direction: column;
		border-left: 1px solid var(--border);
		padding-left: 1.5rem;
		gap: 0;
	}

	.tl-item {
		position: relative;
		padding: 0 0 2rem 0.5rem;
	}
	.tl-item:last-child { padding-bottom: 0; }

	.tl-marker {
		position: absolute;
		left: -1.75rem;
		top: 0.35rem;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--border);
		border: 2px solid var(--bg);
	}

	.tl-item.current .tl-marker {
		background: var(--accent);
		box-shadow: 0 0 0 3px rgba(212,184,150,0.2);
	}

	.tl-item.gap .tl-marker { background: #333; }

	.tl-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.3rem;
	}

	.tl-period {
		font-size: 0.75rem;
		font-family: var(--font-mono);
		color: var(--muted);
	}

	.tl-badge {
		font-size: 0.65rem;
		font-weight: 700;
		padding: 0.1rem 0.5rem;
		border-radius: 999px;
		background: rgba(212,184,150,0.12);
		color: var(--accent);
		letter-spacing: 0.05em;
	}

	.gap-badge {
		background: rgba(255,255,255,0.05);
		color: var(--muted);
	}

	.tl-role {
		font-size: 0.95rem;
		font-weight: 600;
		color: var(--text);
		margin-bottom: 0.15rem;
	}

	.tl-org {
		font-size: 0.8rem;
		color: var(--accent);
		margin-bottom: 0.4rem;
	}

	.tl-desc {
		font-size: 0.85rem;
		color: var(--muted);
		line-height: 1.7;
	}

	/* EDUCATION CARDS */
	.edu-cards {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.edu-card {
		padding: 1.25rem 1.5rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 0.5rem;
		transition: border-color 0.2s;
	}
	.edu-card:hover { border-color: rgba(212,184,150,0.3); }

	.edu-card.highlight { border-left: 3px solid var(--accent); }

	.edu-top {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1rem;
		margin-bottom: 0.4rem;
	}

	.edu-school {
		font-size: 1rem;
		font-weight: 700;
		color: var(--text);
	}

	.edu-degree {
		font-size: 0.88rem;
		color: var(--accent);
		margin-top: 0.15rem;
	}

	.edu-sub {
		font-size: 0.8rem;
		color: var(--muted);
		margin-top: 0.1rem;
	}

	.edu-year {
		font-size: 0.75rem;
		font-family: var(--font-mono);
		color: var(--muted);
		white-space: nowrap;
		padding-top: 0.1rem;
	}

	.edu-location {
		font-size: 0.78rem;
		color: var(--muted);
		margin-bottom: 0.75rem;
	}

	.edu-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
	}

	.edu-tags span {
		font-size: 0.72rem;
		padding: 0.2rem 0.55rem;
		border-radius: 0.25rem;
		background: rgba(212,184,150,0.08);
		color: var(--accent);
		border: 1px solid rgba(212,184,150,0.18);
	}

	/* TOOLS */
	.tools-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.25rem;
	}

	@media (min-width: 600px) {
		.tools-grid { grid-template-columns: 1fr 1fr; }
	}

	.tool-group { display: flex; flex-direction: column; gap: 0.6rem; }

	.tool-label {
		font-size: 0.72rem;
		font-weight: 700;
		font-family: var(--font-mono);
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.tool-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
	}

	.tool-chips span {
		font-size: 0.78rem;
		padding: 0.25rem 0.65rem;
		border-radius: 0.25rem;
		background: var(--surface);
		color: var(--text);
		border: 1px solid var(--border);
		transition: border-color 0.2s;
	}

	.tool-chips span:hover { border-color: var(--accent); color: var(--accent); }

	/* LANGUAGES */
	.lang-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.lang-item {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		padding: 0.75rem 1rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 0.35rem;
	}

	.lang-name {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--text);
		min-width: 80px;
	}

	.lang-level {
		font-size: 0.82rem;
		color: var(--muted);
	}

	/* BEYOND WORK */
	.beyond-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	@media (min-width: 600px) {
		.beyond-grid { grid-template-columns: repeat(3, 1fr); }
	}

	.beyond-card {
		padding: 1.25rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 0.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.beyond-title {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--text);
	}

	.beyond-desc {
		font-size: 0.82rem;
		color: var(--muted);
		line-height: 1.7;
		flex: 1;
	}

	.beyond-link {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		font-size: 0.78rem;
		font-weight: 600;
		color: var(--accent);
		text-decoration: none;
		margin-top: 0.25rem;
		transition: gap 0.2s;
	}
	.beyond-link:hover { gap: 0.5rem; }

	/* RESUME */
	.resume-section {
		align-items: center;
		padding: 2rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 0.5rem;
		text-align: center;
	}

	.resume-text {
		font-size: 0.9rem;
		color: var(--muted);
		margin-bottom: 1rem;
	}

	.resume-btn {
		display: inline-flex;
