---
import { getCollection } from 'astro:content';
import MainHead from '../components/MainHead.astro';

const entries = (await getCollection('writing'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<html lang="en">
<head>
	<MainHead
		title="Writing Work | Vidhya Divakar"
		description="12+ years of technical writing across API documentation, developer guides, training content, and enterprise software docs."
	/>
</head>
<body>

<div class="page">

	<header class="top-nav">
		<a href="/" class="back-link">
			<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="10,3 5,8 10,13"/></svg>
			Back
		</a>
		<span class="top-name">Vidhya Divakar</span>
	</header>

	<main class="content">

		<div class="page-title">
			<h1>Writing Work</h1>
			<p class="subtitle">12+ years across API documentation, developer guides, training content, and enterprise software documentation.</p>
		</div>

		<div class="entries-list">
			{entries.map((entry) => (
				<a href={`/writing/${entry.id}`} class="entry-row">
					<div class="entry-period">{entry.data.period}</div>
					<div class="entry-body">
						<div class="entry-header">
							<h2 class="entry-role">{entry.data.role}</h2>
							<span class="entry-company">{entry.data.title}</span>
						</div>
						<p class="entry-desc">{entry.data.description}</p>
						<div class="entry-tags">
							{entry.data.tags.map((t) => <span class="tag">{t}</span>)}
						</div>
					</div>
					<svg class="arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6,3 11,8 6,13"/></svg>
				</a>
			))}
		</div>

	</main>
</div>

</body>
</html>

<style>
	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

	:root {
		--bg: #0c0c0c; --surface: #0f1117; --border: #252525;
		--text: #f5f5f5; --muted: #b4b4b4; --accent: #d4b896;
		--font-sans: 'Inter', system-ui, sans-serif;
		--font-mono: 'JetBrains Mono', 'Fira Code', monospace;
	}

	html, body { background: var(--bg); color: var(--text); font-family: var(--font-sans); }

	.top-nav {
		position: sticky; top: 0; z-index: 10;
		display: flex; align-items: center; justify-content: space-between;
		padding: 1rem 4vw;
		background: rgba(12,12,12,0.88); backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border);
	}

	.back-link {
		display: inline-flex; align-items: center; gap: 0.4rem;
		font-size: 0.82rem; font-weight: 600; font-family: var(--font-mono);
		color: var(--muted); text-decoration: none; letter-spacing: 0.05em;
		transition: color 0.2s;
	}
	.back-link:hover { color: var(--accent); }
	.top-name { font-size: 0.8rem; font-family: var(--font-mono); color: var(--muted); letter-spacing: 0.08em; }

	.content { max-width: 820px; margin: 0 auto; padding: 4rem 4vw 6rem; display: flex; flex-direction: column; gap: 2.5rem; }

	.page-title h1 { font-size: clamp(1.8rem, 4vw, 2.4rem); font-weight: 700; color: var(--text); }
	.subtitle { margin-top: 0.5rem; font-size: 0.9rem; color: var(--muted); line-height: 1.7; }

	.entries-list { display: flex; flex-direction: column; }

	.entry-row {
		display: grid;
		grid-template-columns: 140px 1fr 20px;
		gap: 1.5rem;
		align-items: start;
		padding: 1.5rem 0;
		border-bottom: 1px solid var(--border);
		text-decoration: none; color: inherit;
		transition: background 0.2s;
	}
	.entry-row:first-child { border-top: 1px solid var(--border); }
	.entry-row:hover .entry-role { color: var(--accent); }
	.entry-row:hover .arrow { opacity: 1; transform: translateX(3px); }

	.entry-period {
		font-size: 0.72rem; font-family: var(--font-mono);
		color: var(--muted); padding-top: 0.2rem; line-height: 1.5;
	}

	.entry-body { display: flex; flex-direction: column; gap: 0.5rem; }

	.entry-header { display: flex; flex-direction: column; gap: 0.2rem; }
	.entry-role { font-size: 0.95rem; font-weight: 600; color: var(--text); transition: color 0.2s; }
	.entry-company { font-size: 0.8rem; color: var(--accent); }

	.entry-desc { font-size: 0.82rem; color: var(--muted); line-height: 1.7; }

	.entry-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
	.tag {
		font-size: 0.7rem; padding: 0.15rem 0.5rem; border-radius: 0.2rem;
		background: rgba(212,184,150,0.08); color: var(--accent);
		border: 1px solid rgba(212,184,150,0.18);
	}

	.arrow {
		width: 14px; height: 14px; color: var(--accent);
		opacity: 0; transition: opacity 0.2s, transform 0.2s;
		margin-top: 0.25rem;
	}

	@media (max-width: 600px) {
		.entry-row { grid-template-columns: 1fr 20px; }
		.entry-period { display: none; }
	}
</style>
