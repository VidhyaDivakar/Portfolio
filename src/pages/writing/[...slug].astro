---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import MainHead from '../../components/MainHead.astro';

interface Props { entry: CollectionEntry<'writing'>; }

export async function getStaticPaths() {
	const entries = await getCollection('writing');
	return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<html lang="en">
<head>
	<MainHead title={`${entry.data.role} at ${entry.data.title} | Vidhya Divakar`} description={entry.data.description} />
</head>
<body>

<div class="page">

	<header class="top-nav">
		<a href="/writing/" class="back-link">
			<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="10,3 5,8 10,13"/></svg>
			Writing Work
		</a>
		<a href="/" class="top-name">Vidhya Divakar</a>
	</header>

	<main class="content">

		<div class="entry-header">
			<div class="entry-meta">
				<span class="entry-period">{entry.data.period}</span>
			</div>
			<h1 class="entry-title">{entry.data.role}</h1>
			<p class="entry-company">{entry.data.title}</p>
			<p class="entry-desc">{entry.data.description}</p>
			<div class="entry-tags">
				{entry.data.tags.map((t) => <span class="tag">{t}</span>)}
			</div>
		</div>

		<div class="prose">
			<Content />
		</div>

		<div class="entry-footer">
			<a href="/writing/" class="back-btn">
				<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="10,3 5,8 10,13"/></svg>
				Back to Writing Work
			</a>
		</div>

	</main>
</div>

</body>
</html>

<style>
	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

	:root {
		--bg: #0c0c0c; --surface: #0f1117; --border: #252525;
		--text: #f5f5f5; --muted: #b4b4b4; --accent: #d4b896;
		--font-sans: 'Inter', system-ui, sans-serif;
		--font-mono: 'JetBrains Mono', 'Fira Code', monospace;
	}

	html, body { background: var(--bg); color: var(--text); font-family: var(--font-sans); }

	.top-nav {
		position: sticky; top: 0; z-index: 10;
		display: flex; align-items: center; justify-content: space-between;
		padding: 1rem 4vw;
		background: rgba(12,12,12,0.88); backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border);
	}

	.back-link, .top-name {
		display: inline-flex; align-items: center; gap: 0.4rem;
		font-size: 0.82rem; font-weight: 600; font-family: var(--font-mono);
		color: var(--muted); text-decoration: none; letter-spacing: 0.05em;
		transition: color 0.2s;
	}
	.back-link:hover, .top-name:hover { color: var(--accent); }

	.content { max-width: 720px; margin: 0 auto; padding: 4rem 4vw 6rem; display: flex; flex-direction: column; gap: 3rem; }

	.entry-header { display: flex; flex-direction: column; gap: 0.75rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); }

	.entry-period { font-size: 0.75rem; font-family: var(--font-mono); color: var(--muted); }

	.entry-title { font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; color: var(--text); line-height: 1.25; }
	.entry-company { font-size: 1rem; color: var(--accent); font-weight: 500; }
	.entry-desc { font-size: 0.9rem; color: var(--muted); line-height: 1.7; }

	.entry-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
	.tag {
		font-size: 0.7rem; padding: 0.15rem 0.5rem; border-radius: 0.2rem;
		background: rgba(212,184,150,0.08); color: var(--accent);
		border: 1px solid rgba(212,184,150,0.18);
	}

	.prose { display: flex; flex-direction: column; gap: 1.25rem; font-size: 0.95rem; line-height: 1.8; color: #d0d0d0; }
	.prose :global(h2) { font-size: 1.15rem; font-weight: 700; color: var(--text); margin-top: 1rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
	.prose :global(h3) { font-size: 1rem; font-weight: 600; color: var(--text); margin-top: 0.5rem; }
	.prose :global(p) { color: #d0d0d0; }
	.prose :global(strong) { color: var(--text); font-weight: 600; }
	.prose :global(ul), .prose :global(ol) { padding-left: 1.5rem; display: flex; flex-direction: column; gap: 0.3rem; }
	.prose :global(li) { color: #d0d0d0; }
	.prose :global(a) { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
	.prose :global(a:hover) { color: #e5ceaf; }
	.prose :global(hr) { border: none; border-top: 1px solid var(--border); }

	.entry-footer { padding-top: 1rem; border-top: 1px solid var(--border); }
	.back-btn {
		display: inline-flex; align-items: center; gap: 0.4rem;
		font-size: 0.82rem; font-weight: 600; font-family: var(--font-mono);
		color: var(--muted); text-decoration: none; letter-spacing: 0.05em;
		transition: color 0.2s;
	}
	.back-btn:hover { color: var(--accent); }
</style>
